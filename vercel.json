{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "frontend/garcom/(.*)", "use": "@vercel/static" },
    { "src": "frontend/admin/(.*)", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/socket.io/(.*)", "dest": "/server.js" },
    { "src": "/garcom/app.js", "dest": "/frontend/garcom/app.js" },
    { "src": "/garcom/style.css", "dest": "/frontend/garcom/style.css" },
    { "src": "/admin/app.js", "dest": "/frontend/admin/app.js" },
    { "src": "/admin/style.css", "dest": "/frontend/admin/style.css" },
    { "src": "/garcom", "dest": "/frontend/garcom/index.html" },
    { "src": "/admin", "dest": "/frontend/admin/index.html" },
    { "src": "/", "dest": "/frontend/garcom/index.html" }
  ]
}
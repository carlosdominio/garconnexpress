{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "frontend/**",
          "motoboy-app-nativo/www/**",
          "cozinha-app-nativo/www/**",
          "garcom-app-nativo/www/**"
        ]
      }
    },
    {
      "src": "*.apk",
      "use": "@vercel/static"
    }
  ],
  "headers": [
    {
      "source": "/(garcom-v1.1.0-portrait.apk|cozinha-v1.1.0-portrait.apk|motoboy-v2.0.0-portrait.apk)",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment"
        },
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        }
      ]
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/server.js" }
  ],
  "crons": [
    {
      "path": "/api/cron/check-delayed-orders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/cardapio",
      "schedule": "0 * * * *"
    }
  ]
}
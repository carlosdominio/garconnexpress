{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "frontend/**",
          "motoboy-app-nativo/www/**",
          "cozinha-app-nativo/www/**",
          "garcom-app-nativo/www/**",
          "garcom-v1.1.0-portrait.apk",
          "cozinha-v1.1.0-portrait.apk",
          "motoboy-v2.0.0-portrait.apk"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}